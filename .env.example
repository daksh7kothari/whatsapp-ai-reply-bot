# Which AI provider to use for replies: "anthropic" or "groq"
AI_PROVIDER=anthropic

# Anthropic API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-5

# Groq API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Target chat to auto-reply in. Get this by running `npm run list-chats` first.
# Format: phone number chat = "911234567890@c.us", group chat = "xxxxx@g.us"
TARGET_CHAT_ID=

# Seconds to wait before replying, mimics human typing delay. Optional, default 0.
REPLY_DELAY_SECONDS=0

# Max characters of exported chat history (from the chat-history/ folder) to
# feed the model as context. Keeps only the most recent part if it's longer.
CHAT_HISTORY_MAX_CHARS=20000
